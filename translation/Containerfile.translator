ARG base_image
FROM ${base_image} as base

LABEL maintainer="CSC Service Desk <servicedesk@csc.fi>"

ARG restic_version
COPY --from=ghcr.io/restic/restic:${restic_version} \
     /usr/bin/restic \
     /usr/bin/restic

ADD translation/requirements.txt ./

ARG PIP_ROOT_USER_ACTION=ignore
RUN \
  pip3 install --upgrade pip \
&& \
  pip3 install --requirement=requirements.txt

ADD translation/translator/ ./translator/
ADD translation/refresh_translation.py \
    translation/clear_cache.py \
    ./

ADD --chown=0:0 \
    --chmod=774 \
  translation/entrypoint.translator.bash /entrypoint.bash

ARG repo_org=CSCfi
ARG repo_name=csc-user-guide
ARG repo_branch=master
ENV REPO_ORG=${repo_org} \
    REPO_NAME=${repo_name} \
    REPO_BRANCH=${repo_branch} \
    DOCS_DIR=docs \
    RESTIC_CACHE_DIR=/.restic-cache

RUN \
  mkdir --mode 775 "${RESTIC_CACHE_DIR}"

ENTRYPOINT ["/entrypoint.bash"]
